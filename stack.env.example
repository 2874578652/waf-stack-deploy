# WAF stack deployment template for the current production layout.
# Verified against:
# - WAF repo: 2874578652/waf (main)
# - Bot repo: 2874578652/bot (main)
# - Runtime layout: host nginx + ModSecurity + wafbot under /opt/wafbot
#
# Private repository access is expected to use SSH host aliases:
# - github-waf -> git@github.com:2874578652/waf.git
# - github-bot -> git@github.com:2874578652/bot.git

# Source repositories
WAF_REPO_URL=git@github-waf:2874578652/waf.git
WAF_REPO_BRANCH=main
BOT_REPO_URL=git@github-bot:2874578652/bot.git
BOT_REPO_BRANCH=main

# Deployment source mode.
# 0 = clone/update waf and bot from their own repositories
# 1 = deploy from bundles/waf and bundles/bot inside this repository
# Default is bundle mode so a new server only needs this single repository.
USE_LOCAL_BUNDLES=1
WAF_BUNDLE_DIR=
BOT_BUNDLE_DIR=

# Local checkout paths on the target host.
# These are only source working trees used for update/install orchestration.
WAF_SRC_DIR=/opt/src/waf
BOT_SRC_DIR=/opt/src/wafbot

# Runtime install paths expected by the current stack.
# The WAF repo syncs into /etc/nginx and /etc/nginx/modsec.
# The bot install script deploys into /opt/wafbot.
WAF_INSTALL_NGINX_DIR=/etc/nginx
WAF_INSTALL_MODSEC_DIR=/etc/nginx/modsec
BOT_INSTALL_DIR=/opt/wafbot

# Services and binaries used on the current source server.
NGINX_SERVICE=nginx
NGINX_BIN=nginx
BOT_SERVICE_NAME=wafbot

# Base system packages for Debian/Ubuntu-like hosts.
# libnginx-mod-http-modsecurity is required by the current WAF layout.
INSTALL_SYSTEM_PACKAGES=1
SYSTEM_PACKAGES=ca-certificates curl git rsync nginx python3 python3-venv python3-pip libnginx-mod-http-modsecurity

# OWASP CRS source expected by the current WAF repository.
# The WAF config currently points at:
# /etc/nginx/modsec/coreruleset-4.24.1
INSTALL_CRS=1
CRS_REPO_URL=https://github.com/coreruleset/coreruleset.git
CRS_GIT_REF=v4.24.1
CRS_INSTALL_DIR=/etc/nginx/modsec/coreruleset-4.24.1

# Timestamped backups created before config replacement.
WAF_BACKUP_ROOT=/root/waf-stack-backups

# Bot secret injection.
# Put the real production bot env file on the target host, for example:
#   /root/secrets/wafbot.env
# The installer will copy it into:
#   /opt/wafbot/.env
BOT_ENV_FILE=/root/secrets/wafbot.env
BOT_AUTO_START=1

# Post-sync behavior.
# START_NGINX=1 means start nginx if inactive.
# RELOAD_NGINX=1 means reload nginx after a successful config sync.
# RUN_STACK_CHECK=1 runs nginx -t, Python compile checks, and service status checks.
START_NGINX=1
RELOAD_NGINX=1
RUN_STACK_CHECK=1
