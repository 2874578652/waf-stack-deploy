# Copy this file onto the target host as:
#   /root/secrets/wafbot.env
#
# Then replace the placeholder values with the real production values.
# Do not commit the real file back into Git.

# Telegram Bot Token from @BotFather
BOT_TOKEN=1234567890:replace_me

# Comma-separated Telegram user IDs allowed to manage the bot
ALLOWED_USERS=123456789

# Optional comma-separated allowed group/supergroup chat IDs
# Leave empty to allow read-only group mode in any group the bot joins
ALLOWED_GROUPS=

# Chat ID that receives attack alerts
# Group IDs are typically negative, for example: -1001234567890
ALERT_CHAT_ID=-1001234567890

# ModSecurity audit log path
MODSEC_AUDIT_LOG=/var/log/modsec_audit.log

# Alert polling interval in seconds
ALERT_INTERVAL=30

# Nginx binary / service name
NGINX_BIN=nginx
NGINX_SERVICE=nginx

# WAF file paths used by the bot
IP_BLACKLIST=/etc/nginx/modsec/custom/ipblacklist.data
IP_WHITELIST=/etc/nginx/modsec/custom/ipwhitelist.data
CC_WHITELIST_INCLUDE=/etc/nginx/modsec/custom/ipwhitelist_cc.inc
MODSEC_CONF=/etc/nginx/modsec/modsecurity.conf

# Optional custom SQLite database path; leave empty for /opt/wafbot/wafbot.db
DB_PATH=
